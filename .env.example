# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://membres.ressources-fitness.com
APP_NAME="RESSOURCES"

# Base de données MySQL (Amen)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ressources_hub
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# SMTP — emails (invitations, reset mot de passe, notifications)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=ressources@fitness-challenges.com
MAIL_FROM_NAME="RESSOURCES"

# Sécurité
# Clé AES 256 bits (générer avec : php -r "echo bin2hex(random_bytes(32));")
APP_SECRET=
SESSION_NAME=ressources_sess
SESSION_LIFETIME=86400

# TLS : DOIT être à true en production. Le passer à false uniquement en dev local
# si un antivirus (Avast, Kaspersky...) intercepte HTTPS et fait échouer la vérification.
APP_TLS_VERIFY=true

# Token aléatoire pour autoriser /install au premier déploiement.
# Génère avec : php -r "echo bin2hex(random_bytes(16));"
# Une fois l'installation lancée avec succès, tu peux retirer cette ligne par sécurité
# (le verrou storage/install.lock empêche déjà toute relance).
INSTALL_TOKEN=

# --- Intégrations (branchées dans les lots suivants, laisser vide pour le lot 1) ---

# Vidéo — Vimeo Pro (personal access token, privé + restriction de domaine)
VIMEO_ACCESS_TOKEN=

# Assistant IA (RAG) — clé API du LLM (Claude par défaut) + modèle d'embeddings
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Secret pour signer les liens de téléchargement PDF (HMAC, différent de APP_SECRET)
DOWNLOAD_SECRET=
